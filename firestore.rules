rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function customerPath(customerId) {
      return /databases/$(database)/documents/customers/$(customerId);
    }

    function isSignedInUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserExists() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function currentUserData() {
      return get(userPath(request.auth.uid)).data;
    }

    function currentOwnerId() {
      return ('ownerId' in currentUserData()
              && currentUserData().ownerId is string
              && currentUserData().ownerId.size() > 0)
          ? currentUserData().ownerId
          : request.auth.uid;
    }

    function ownerIdForUser(userId) {
      return ('ownerId' in get(userPath(userId)).data
              && get(userPath(userId)).data.ownerId is string
              && get(userPath(userId)).data.ownerId.size() > 0)
          ? get(userPath(userId)).data.ownerId
          : currentOwnerId();
    }

    function isAdmin() {
      return currentUserExists()
          && currentUserData().role == 'admin'
          && currentUserData().isActive == true;
    }

    function isDeliveryBoy() {
      return currentUserExists()
          && currentUserData().role == 'delivery_boy'
          && currentUserData().isActive == true;
    }

    function isValidUserRole(role) {
      return role == 'admin' || role == 'delivery_boy';
    }

    function optionalString(data, key) {
      return !(key in data) || data[key] is string;
    }

    function optionalNumber(data, key) {
      return !(key in data) || (data[key] is number && data[key] >= 0);
    }

    function optionalBool(data, key) {
      return !(key in data) || data[key] is bool;
    }

    function optionalTimestamp(data, key) {
      return !(key in data) || data[key] is timestamp;
    }

    function isValidOwnerSignupData(userId) {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'name',
            'email',
            'phone',
            'role',
            'isActive',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'name',
            'email',
            'role',
            'isActive',
          ])
          && data.ownerId == userId
          && data.name is string
          && data.name.size() > 0
          && data.email is string
          && data.email.size() > 0
          && optionalString(data, 'phone')
          && data.role == 'admin'
          && data.isActive == true
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function isValidAdminManagedUserData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'name',
            'email',
            'phone',
            'role',
            'isActive',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'name',
            'email',
            'role',
            'isActive',
          ])
          && data.ownerId == currentOwnerId()
          && data.name is string
          && data.name.size() > 0
          && data.email is string
          && data.email.size() > 0
          && optionalString(data, 'phone')
          && isValidUserRole(data.role)
          && data.isActive is bool
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function ownerScopedRead() {
      return resource.data.ownerId == currentOwnerId();
    }

    function ownerScopedWrite() {
      return request.resource.data.ownerId == currentOwnerId();
    }

    function deliveryBoyExists(deliveryBoyId, ownerId) {
      return deliveryBoyId is string
          && deliveryBoyId.size() > 0
          && exists(userPath(deliveryBoyId))
          && get(userPath(deliveryBoyId)).data.role == 'delivery_boy'
          && get(userPath(deliveryBoyId)).data.isActive == true
          && ownerIdForUser(deliveryBoyId) == ownerId;
    }

    function isValidCustomerData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'name',
            'phone',
            'address',
            'morningQty',
            'eveningQty',
            'assignedDeliveryBoyId',
            'ratePerLiter',
            'subscriptions',
            'isActive',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'name',
            'phone',
            'address',
            'morningQty',
            'eveningQty',
            'assignedDeliveryBoyId',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.name is string
          && data.name.size() > 0
          && data.phone is string
          && data.phone.size() > 0
          && data.address is string
          && data.address.size() > 0
          && data.morningQty is number
          && data.morningQty >= 0
          && data.eveningQty is number
          && data.eveningQty >= 0
          && deliveryBoyExists(data.assignedDeliveryBoyId, data.ownerId)
          && optionalNumber(data, 'ratePerLiter')
          && (!('subscriptions' in data)
              || (data.subscriptions is list
                  && data.subscriptions.size() <= 200))
          && optionalBool(data, 'isActive')
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function customerData(customerId) {
      return get(customerPath(customerId)).data;
    }

    function customerBelongsToOwner(customerId, ownerId) {
      return exists(customerPath(customerId))
          && customerData(customerId).ownerId == ownerId;
    }

    function isActiveCustomerForDeliveryBoy(customerId, deliveryBoyId) {
      return exists(customerPath(customerId))
          && customerData(customerId).assignedDeliveryBoyId == deliveryBoyId
          && customerData(customerId).ownerId == currentOwnerId()
          && (!('isActive' in customerData(customerId))
              || customerData(customerId).isActive == true);
    }

    function isValidDeliveryData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'customerId',
            'customerName',
            'deliveryBoyId',
            'date',
            'dateKey',
            'monthKey',
            'shift',
            'subscriptionId',
            'productId',
            'productName',
            'unitLabel',
            'plannedQty',
            'deliveredQty',
            'ratePerLiter',
            'status',
            'updatedBy',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'customerId',
            'customerName',
            'deliveryBoyId',
            'date',
            'dateKey',
            'monthKey',
            'shift',
            'plannedQty',
            'deliveredQty',
            'status',
            'updatedBy',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.customerId is string
          && data.customerId.size() > 0
          && customerBelongsToOwner(data.customerId, data.ownerId)
          && data.customerName is string
          && data.customerName.size() > 0
          && data.deliveryBoyId is string
          && data.deliveryBoyId.size() > 0
          && ownerIdForUser(data.deliveryBoyId) == data.ownerId
          && data.date is timestamp
          && data.dateKey is string
          && data.dateKey.size() > 0
          && data.monthKey is string
          && data.monthKey.size() > 0
          && (data.shift == 'morning' || data.shift == 'evening')
          && optionalString(data, 'subscriptionId')
          && optionalString(data, 'productId')
          && optionalString(data, 'productName')
          && optionalString(data, 'unitLabel')
          && data.plannedQty is number
          && data.plannedQty >= 0
          && data.deliveredQty is number
          && data.deliveredQty >= 0
          && ((data.deliveredQty == 0 && data.status == 'pending')
              || (data.deliveredQty > 0 && data.status == 'delivered'))
          && data.updatedBy is string
          && data.updatedBy.size() > 0
          && optionalNumber(data, 'ratePerLiter')
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function isValidPaymentMode(mode) {
      return mode == 'cash' || mode == 'upi' || mode == 'bank_transfer';
    }

    function isValidPaymentData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'customerId',
            'amount',
            'date',
            'monthKey',
            'paymentMode',
            'createdBy',
            'notes',
          ])
          && data.keys().hasAll([
            'ownerId',
            'customerId',
            'amount',
            'date',
            'monthKey',
            'paymentMode',
            'createdBy',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.customerId is string
          && data.customerId.size() > 0
          && customerBelongsToOwner(data.customerId, data.ownerId)
          && data.amount is number
          && data.amount > 0
          && data.date is timestamp
          && data.monthKey is string
          && data.monthKey.size() > 0
          && data.paymentMode is string
          && isValidPaymentMode(data.paymentMode)
          && data.createdBy is string
          && data.createdBy.size() > 0
          && optionalString(data, 'notes');
    }

    function isValidVendorPurchaseData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'vendorName',
            'quantity',
            'rate',
            'totalAmount',
            'date',
            'monthKey',
            'createdBy',
          ])
          && data.keys().hasAll([
            'ownerId',
            'vendorName',
            'quantity',
            'rate',
            'totalAmount',
            'date',
            'monthKey',
            'createdBy',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.vendorName is string
          && data.vendorName.size() > 0
          && data.quantity is number
          && data.quantity > 0
          && data.rate is number
          && data.rate > 0
          && data.totalAmount is number
          && data.totalAmount >= 0
          && data.date is timestamp
          && data.monthKey is string
          && data.monthKey.size() > 0
          && data.createdBy is string
          && data.createdBy.size() > 0;
    }

    function isValidCustomerLeaveData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'customerId',
            'customerName',
            'startDate',
            'endDate',
            'startDateKey',
            'endDateKey',
            'morningOff',
            'eveningOff',
            'productTargets',
            'note',
            'createdBy',
            'isActive',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'customerId',
            'customerName',
            'startDate',
            'endDate',
            'startDateKey',
            'endDateKey',
            'morningOff',
            'eveningOff',
            'createdBy',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.customerId is string
          && data.customerId.size() > 0
          && customerBelongsToOwner(data.customerId, data.ownerId)
          && data.customerName is string
          && data.customerName == customerData(data.customerId).name
          && data.startDate is timestamp
          && data.endDate is timestamp
          && data.startDate <= data.endDate
          && data.startDateKey is string
          && data.startDateKey.size() > 0
          && data.endDateKey is string
          && data.endDateKey.size() > 0
          && data.morningOff is bool
          && data.eveningOff is bool
          && (data.morningOff || data.eveningOff)
          && (!('productTargets' in data)
              || (data.productTargets is list
                  && data.productTargets.size() <= 100))
          && data.createdBy is string
          && data.createdBy.size() > 0
          && optionalString(data, 'note')
          && optionalBool(data, 'isActive')
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function isValidProductData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'name',
            'unitLabel',
            'defaultRate',
            'isActive',
            'notes',
            'createdAt',
            'updatedAt',
          ])
          && data.keys().hasAll([
            'ownerId',
            'name',
            'unitLabel',
            'defaultRate',
            'isActive',
          ])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.name is string
          && data.name.size() > 0
          && data.unitLabel is string
          && data.unitLabel.size() > 0
          && data.defaultRate is number
          && data.defaultRate >= 0
          && data.isActive is bool
          && optionalString(data, 'notes')
          && optionalTimestamp(data, 'createdAt')
          && optionalTimestamp(data, 'updatedAt');
    }

    function isValidDairyProfileData() {
      let data = request.resource.data;

      return data.keys().hasOnly([
            'ownerId',
            'dairyName',
            'ownerName',
            'phone',
            'email',
            'address',
            'paymentQrBase64',
            'bankName',
            'accountHolderName',
            'accountNumber',
            'ifscCode',
            'branchName',
            'updatedAt',
          ])
          && data.keys().hasAll(['ownerId'])
          && data.ownerId == currentOwnerId()
          && optionalString(data, 'dairyName')
          && optionalString(data, 'ownerName')
          && optionalString(data, 'phone')
          && optionalString(data, 'email')
          && optionalString(data, 'address')
          && optionalString(data, 'bankName')
          && optionalString(data, 'accountHolderName')
          && optionalString(data, 'accountNumber')
          && optionalString(data, 'ifscCode')
          && optionalString(data, 'branchName')
          && (!('paymentQrBase64' in data)
              || (data.paymentQrBase64 is string
                  && data.paymentQrBase64.size() < 1000000))
          && optionalTimestamp(data, 'updatedAt');
    }

    function isDeliveryBoyDeliveryWrite() {
      let data = request.resource.data;

      return isDeliveryBoy()
          && isValidDeliveryData()
          && data.ownerId == currentOwnerId()
          && data.deliveryBoyId == request.auth.uid
          && data.updatedBy == request.auth.uid
          && isActiveCustomerForDeliveryBoy(data.customerId, request.auth.uid)
          && data.customerName == customerData(data.customerId).name;
    }

    match /users/{userId} {
      allow get: if isSignedInUser(userId)
          || (isAdmin() && ownerScopedRead());
      allow list: if isAdmin();
      allow create: if isSignedInUser(userId)
          && isValidOwnerSignupData(userId)
          || (isAdmin() && isValidAdminManagedUserData());
      allow update: if isAdmin() && isValidAdminManagedUserData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /customers/{customerId} {
      allow read: if (isAdmin() && ownerScopedRead())
          || (isDeliveryBoy()
              && ownerScopedRead()
              && resource.data.assignedDeliveryBoyId == request.auth.uid
              && (!('isActive' in resource.data) || resource.data.isActive == true));
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && isValidCustomerData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /deliveries/{deliveryId} {
      allow read: if (isAdmin() && ownerScopedRead())
          || (isDeliveryBoy()
              && ownerScopedRead()
              && resource.data.deliveryBoyId == request.auth.uid);
      allow create, update: if (isAdmin()
          && ownerScopedWrite()
          && isValidDeliveryData())
          || isDeliveryBoyDeliveryWrite();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() && ownerScopedRead();
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && isValidPaymentData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /vendor_purchases/{purchaseId} {
      allow read: if isAdmin() && ownerScopedRead();
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && isValidVendorPurchaseData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /customer_leaves/{leaveId} {
      allow read: if (isAdmin() && ownerScopedRead())
          || (isDeliveryBoy() && ownerScopedRead());
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && isValidCustomerLeaveData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /products/{productId} {
      allow read: if (isAdmin() && ownerScopedRead())
          || (isDeliveryBoy() && ownerScopedRead());
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && isValidProductData();
      allow delete: if isAdmin() && ownerScopedRead();
    }

    match /app_settings/{documentId} {
      allow read: if isAdmin()
          && ownerScopedRead()
          && documentId == currentOwnerId() + '_dairy_profile';
      allow create, update: if isAdmin()
          && ownerScopedWrite()
          && documentId == currentOwnerId() + '_dairy_profile'
          && isValidDairyProfileData();
      allow delete: if isAdmin()
          && ownerScopedRead()
          && documentId == currentOwnerId() + '_dairy_profile';
    }

    match /settings/{documentId} {
      allow read: if isAdmin() || isDeliveryBoy();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
